# 前端 Dockerfile
FROM node:18-alpine AS build

WORKDIR /app

# 复制 package 文件
COPY client/package*.json ./
RUN npm install

# 复制源代码
COPY client/ ./

# 构建
RUN npm run build

# 运行阶段 - 使用 nginx 提供静态文件
FROM nginx:alpine

# 复制构建产物
COPY --from=build /app/dist /usr/share/nginx/html

# 复制 nginx 配置
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
